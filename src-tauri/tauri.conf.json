{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Atena",
  "version": "0.1.5",
  "identifier": "io.atenaproject.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Atena",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Atena Project",
    "homepage": "https://github.com/Gabriel-faustino-lab/Atena-multi-agent",
    "shortDescription": "Centro de comando local para agentes de inteligência artificial",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["PortugueseBR", "English"],
        "installerIcon": "icons/icon.ico",
        "installerHooks": "./windows/hooks.nsh",
        "startMenuFolder": "Atena"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyNUUxMzA4MzZDQTVERjAKUldUd1hjbzJDQk5la2hteEpQSHFoMW9Za3V2aVZXWko0VFpSV3EwdjU5ZUJyVEVYNzdFRTBNV0YK",
      "endpoints": [
        "https://github.com/Gabriel-faustino-lab/Atena-multi-agent/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
